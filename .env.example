# Server
PORT=8082

# Whisper transcription
# Path to your whisper binary (mlx_whisper, whisper, etc.)
WHISPER_BIN=whisper
# Model name (e.g., "small", "medium", "mlx-community/whisper-small-mlx")
WHISPER_MODEL=small
# Language code (e.g., "en", "es")
WHISPER_LANG=en
# Extra PATH entries for finding the whisper binary (colon-separated)
# WHISPER_PATH=/path/to/venv/bin:/opt/homebrew/bin

# Cloudflare Access identity mapping (optional)
# Maps CF Access email to a friendly name for multi-user setups.
# EMAIL_MAP='{"alice@example.com":"alice","bob@example.com":"bob"}'

# Transcript cleanup with Claude (optional)
# If set, raw Whisper output is cleaned up before saving.
# ANTHROPIC_API_KEY=sk-ant-...
# CLEANUP_MODEL=claude-haiku-4-5-20251001

# Webhook notification (optional)
# POST JSON {author, filename, transcript, timestamp} after transcription.
# NOTIFY_WEBHOOK_URL=https://your-service.example.com/hook

# SSH relay targets (optional)
# Relay recordings to other machines via SSH/SCP.
# RELAY_TARGETS='{"myserver":{"host":"myserver","path":"~/recordings/"}}'

# Audio cleanup
# Days to keep audio files before pruning (transcripts are kept).
PRUNE_AGE_DAYS=7
